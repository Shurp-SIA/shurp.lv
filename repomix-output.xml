    <script>
        function openOverlay(id) {
            var el = document.getElementById('overlay-' + id);
            if (!el) return;
            el.classList.add('open');
            el.scrollTop = 0;
            document.body.style.overflow = 'hidden';
            history.pushState({ overlay: id }, '');
        }
        function closeOverlay(id) {
            var el = document.getElementById('overlay-' + id);
            if (!el) return;
            el.classList.remove('open');
            document.body.style.overflow = '';
        }
        window.addEventListener('popstate', function () {
            document.querySelectorAll('.overlay.open').forEach(function (el) {
                el.classList.remove('open');
            });
            document.body.style.overflow = '';
        });
        function toggleFaq(el) {
            var item = el.closest('.faq-item');
            var wasOpen = item.classList.contains('open');
            item.closest('.overlay-body').querySelectorAll('.faq-item').forEach(function (i) {
                i.classList.remove('open');
            });
            if (!wasOpen) item.classList.add('open');
        }
        var HELP_ENDPOINT = 'https://okyprkffbuorrtlhnplf.supabase.co/functions/v1/help-request';
        var TURNSTILE_SITEKEY = '0x4AAAAAACjXgi-e6gTBacXk';
        var MAX_MESSAGE_LENGTH = 2000;
        var HELP_AUTH_TOKEN = null;
        var turnstileWidgetId = null;
        var pendingTurnstileResolve = null;
        var pendingTurnstileReject = null;

        (function readLegacyQueryToken() {
            var url = new URL(window.location.href);
            var token = url.searchParams.get('token');
            if (token) {
                HELP_AUTH_TOKEN = token;
                url.searchParams.delete('token');
                history.replaceState(null, '', url.pathname + url.search + url.hash);
            }
        })();

        window.setShurpAuthToken = function (token) {
            if (typeof token === 'string' && token.trim()) {
                HELP_AUTH_TOKEN = token.trim();
                resetTurnstile();
            }
        };

        function setBanner(message, isError) {
            var banner = document.getElementById('success-banner');
            banner.textContent = message;
            banner.classList.toggle('error', !!isError);
            banner.style.display = 'block';
        }

        function isValidEmail(email) {
            return email.length <= 50 && /^[^\s@]+@[^\s@]+\.[A-Za-z]{2,}$/.test(email);
        }

        function setEmailError(message) {
            var emailInput = document.getElementById('contact-email');
            var helper = document.getElementById('email-helper');
            emailInput.classList.add('error');
            helper.classList.add('error');
            helper.textContent = message;
        }

        function clearEmailError() {
            var emailInput = document.getElementById('contact-email');
            var helper = document.getElementById('email-helper');
            emailInput.classList.remove('error');
            helper.classList.remove('error');
            helper.textContent = helper.getAttribute('data-default');
        }

        function validateOptionalEmail(email) {
            if (!email || isValidEmail(email)) {
                clearEmailError();
                return true;
            }
            setEmailError('Please enter a valid email address, for example name@example.com.');
            return false;
        }

        function buildSupportMessage(msg, email) {
            return email ? 'Reply-to email: ' + email + '\n\n' + msg : msg;
        }

        function updateCharCounter() {
            var msg = document.getElementById('msg-text').value;
            document.getElementById('char-counter').textContent = msg.length + ' / ' + MAX_MESSAGE_LENGTH;
        }

        function renderTurnstileOnce() {
            var container = document.getElementById('turnstile-container');
            if (!container || turnstileWidgetId !== null || !window.turnstile) return;

            turnstileWidgetId = turnstile.render(container, {
                sitekey: TURNSTILE_SITEKEY,
                size: 'invisible',
                callback: function (token) {
                    if (pendingTurnstileResolve) pendingTurnstileResolve(token);
                    pendingTurnstileResolve = null;
                    pendingTurnstileReject = null;
                },
                'error-callback': function () {
                    if (pendingTurnstileReject) pendingTurnstileReject(new Error('Turnstile failed'));
                    pendingTurnstileResolve = null;
                    pendingTurnstileReject = null;
                    resetTurnstile();
                },
                'expired-callback': function () {
                    resetTurnstile();
                }
            });
        }

        function getTurnstileToken() {
            if (HELP_AUTH_TOKEN) return Promise.resolve(null);
            if (!window.turnstile || turnstileWidgetId === null) {
                return Promise.reject(new Error('Security check is still loading. Please try again in a moment.'));
            }

            var existingToken = turnstile.getResponse(turnstileWidgetId);
            if (existingToken) return Promise.resolve(existingToken);

            return new Promise(function (resolve, reject) {
                pendingTurnstileResolve = resolve;
                pendingTurnstileReject = reject;
                turnstile.execute(turnstileWidgetId);
            });
        }

        function resetTurnstile() {
            if (window.turnstile && turnstileWidgetId !== null) {
                turnstile.reset(turnstileWidgetId);
            }
        }

        function buildMailto(msg, type, email) {
            return 'mailto:info@shurp.lv?subject='
                + encodeURIComponent('Shurp Help: ' + type)
                + '&body=' + encodeURIComponent('[Type: ' + type + ']\n\n' + buildSupportMessage(msg, email));
        }

        function buildWebMailUrl(msg, type, email) {
            return 'https://mail.google.com/mail/?view=cm&fs=1&to='
                + encodeURIComponent('info@shurp.lv')
                + '&su=' + encodeURIComponent('Shurp Help: ' + type)
                + '&body=' + encodeURIComponent('[Type: ' + type + ']\n\n' + buildSupportMessage(msg, email));
        }

        function openMailFallback() {
            var msg = document.getElementById('msg-text').value.trim();
            var type = document.getElementById('msg-type').value || 'Other';
            var email = document.getElementById('contact-email').value.trim();
            if (!validateOptionalEmail(email)) return;
            if (buildSupportMessage(msg, email).length > MAX_MESSAGE_LENGTH) { alert('Please keep your message under 2000 characters.'); return; }
            var isAndroid = /Android/i.test(navigator.userAgent);
            window.location.href = isAndroid ? buildWebMailUrl(msg, type, email) : buildMailto(msg, type, email);
        }

        async function submitForm(button) {
            var msg = document.getElementById('msg-text').value.trim();
            var email = document.getElementById('contact-email').value.trim();
            var typeEl = document.getElementById('msg-type');
            var type = typeEl.value;
            if (!msg) { alert('Please describe your issue first.'); return; }
            if (!type) { alert('Please choose a message type.'); return; }
            if (!validateOptionalEmail(email)) return;
            if (buildSupportMessage(msg, email).length > MAX_MESSAGE_LENGTH) { alert('Please keep your message under 2000 characters.'); return; }

            var submitButton = button || document.getElementById('submit-btn');
            var originalText = submitButton.textContent;
            submitButton.disabled = true;
            submitButton.textContent = 'Sending...';

            try {
                var turnstileToken = await getTurnstileToken();
                var headers = { 'Content-Type': 'application/json' };
                if (HELP_AUTH_TOKEN) headers.Authorization = 'Bearer ' + HELP_AUTH_TOKEN;

                var response = await fetch(HELP_ENDPOINT, {
                    method: 'POST',
                    headers: headers,
                    body: JSON.stringify({
                        message: buildSupportMessage(msg, email),
                        type: type,
                        lang: 'en',
                        contact_email: email || null,
                        turnstile_token: turnstileToken,
                        page_url: window.location.href,
                        user_agent: navigator.userAgent,
                        source: HELP_AUTH_TOKEN ? 'app' : 'web'
                    })
                });

                if (!response.ok) {
                    var errorText = await response.text();
                    throw new Error(errorText || 'Request failed');
                }

                setBanner("Sent! We'll get back to you shortly.", false);
                document.getElementById('msg-text').value = '';
                document.getElementById('contact-email').value = '';
                typeEl.value = '';
                typeEl.classList.remove('filled');
                updateCharCounter();
                resetTurnstile();
            } catch (err) {
                console.error('Help request failed:', err);
                setBanner('Could not send right now. Please try again or use the email fallback below.', true);
                resetTurnstile();
            } finally {
                submitButton.disabled = false;
                submitButton.textContent = originalText;
            }
        }
        // Hash deep-link: /en/help#ask → scroll to form
        function handleHash() {
            if (window.location.hash === '#ask') {
                setTimeout(function () {
                    var el = document.getElementById('ask-section');
                    if (el) el.scrollIntoView({ behavior: 'smooth' });
                }, 150);
            }
        }
        window.addEventListener('load', function () {
            updateCharCounter();
            if (window.turnstile) {
                renderTurnstileOnce();
            } else {
                var check = setInterval(function () {
                    if (window.turnstile) {
                        renderTurnstileOnce();
                        clearInterval(check);
                    }
                }, 100);
            }
        });
        window.addEventListener('load', handleHash);
        window.addEventListener('hashchange', handleHash);
    </script>

</body>

</html>
