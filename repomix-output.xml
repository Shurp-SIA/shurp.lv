    <script>
        const TURNSTILE_SITEKEY = '0x4AAAAAACjXgi-e6gTBacXk';
        let turnstileWidgetId = null;

        function renderTurnstileOnce() {
            const container = document.getElementById('turnstile-container');
            if (!container || turnstileWidgetId !== null) return;

            turnstileWidgetId = turnstile.render(container, {
                sitekey: TURNSTILE_SITEKEY,
                theme: 'light'
            });
        }

        window.addEventListener('load', () => {
            if (window.turnstile) {
                renderTurnstileOnce();
            } else {
                const check = setInterval(() => {
                    if (window.turnstile) {
                        renderTurnstileOnce();
                        clearInterval(check);
                    }
                }, 100);
            }
        });
        function toggleModal() {
            const modal = document.getElementById('cta-modal');
            modal.classList.toggle('active');
        }

        function closeModal(e) {
            if (e.target.id === 'cta-modal') toggleModal();
        }

        document.getElementById('waitlist-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email-input').value;
            const submitBtn = document.getElementById('submit-btn');

            if (turnstileWidgetId === null) {
                alert('Drošības pārbaude vēl nav ielādēta. Lūdzu, uzgaidiet.');
                return;
            }

            const token = turnstile.getResponse(turnstileWidgetId);

            if (!token) {
                alert('Lūdzu, apstipriniet, ka neesat robots.');
                return;
            }

            if (!/^\S+@\S+\.\S+$/.test(email)) {
                alert('Lūdzu ievadiet derīgu e-pastu.');
                return;
            }

            submitBtn.innerText = 'Sūta...';
            submitBtn.disabled = true;

            try {
                const res = await fetch(
                    'https://ypfryryaujlvidyfzybk.supabase.co/functions/v1/waitlist',
                    {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            email: email,
                            token: token,
                            lang: 'lv'
                        })
                    }
                );

                if (!res.ok) {
                    const text = await res.text();
                    throw new Error(text);
                }
            } catch (err) {
                alert('Kļūda: ' + err.message);
                submitBtn.innerText = 'Mēģināt vēlreiz';
                submitBtn.disabled = false;
                if (turnstileWidgetId !== null) {
                    turnstile.reset(turnstileWidgetId);
                }
                return;
            }

            turnstile.reset(turnstileWidgetId);

            submitBtn.innerText = 'Paldies! Tu esi sarakstā.';
            setTimeout(() => {
                toggleModal();
                submitBtn.innerText = 'Paziņo man';
                submitBtn.disabled = false;
                e.target.reset();
            }, 2000);
        });

        document.getElementById('safe-email').textContent = 'info' + '@' + 'shurp.lv';
    </script>
