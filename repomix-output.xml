@import "tailwindcss";

@layer components {
    .nav-bar {
        @apply fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 md:px-12 py-6 bg-[#125E8A]/95 border-b border-white/10 backdrop-blur-md;
    }

    .legal-card {
        /* Changed mx-auto to block to ensure centering works with Tailwind v4 layout engine */
        @apply block max-w-[800px] mt-[120px] mb-[60px] mx-auto p-6 md:p-10 rounded-[2.5rem] bg-[#FFF9F5] border border-[#E2E8F0] shadow-xl;
    }

    .legal-section {
        @apply mb-14 last:mb-0;
    }

    .legal-section h2 {
        @apply text-xl font-bold mb-5 text-[#1F2933] border-l-4 border-[#125E8A] pl-4 leading-tight;
    }

    .legal-section p {
        @apply opacity-70 mb-4 leading-relaxed;
    }

    /* Important: Ensure strong tags override the paragraph opacity */
    .legal-section strong {
        @apply opacity-100 text-[#1F2933] font-semibold;
    }

    .compact-list {
        @apply list-none p-0 opacity-70 mb-4;
    }

    .compact-list li {
        @apply mb-2 relative pl-6 before:content-['•'] before:absolute before:left-0 before:text-[#125E8A] before:font-bold;
    }

    .highlight-box {
        @apply bg-[#125E8A]/10 p-6 md:p-8 rounded-[1.5rem] border border-dashed border-[#125E8A]/30 mb-8;
    }

    /* Target the text inside highlight box to be more readable */
    .highlight-box p {
        @apply opacity-100;
    }

    .legal-footer-box {
        @apply bg-[#E6F1F7] p-6 md:p-8 rounded-[1.5rem] border border-[#E2E8F0];
    }
}
