<file path="public/en/help.html">
<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="robots" content="noindex, nofollow">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Shurp | Help</title>
    <!--
        style.css is compiled Tailwind v4 output — already includes base reset.
        We only add page-specific component styles below.
        .htaccess handles clean URL: /en/help → /en/help.html automatically.
    -->
    <link href="../assets/css/style.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer></script>
    <style>
        /* ── FLUTTER TOKEN MIRROR ───────────────────────────────────────────
           AppColors.balticBlue      #125E8A  → --c-primary
           AppColors.warmWhite       #FFF9F5  → --c-bg
           AppColors.coolGrey / outline #E2E8F0 → --c-outline  (exact match)
           AppColors.darkGrey        #1F2933  → --c-text
           AppColors.mediumGrey      #6B7280  → --c-muted
           AppColors.softBlue        #E6F1F7  → --c-surface
           AppRadius.sm = 20, md = 25 → cards use 16px (mobile feel)
           AppSpacing.lg = 16px padding
        ────────────────────────────────────────────────────────────────────── */
        :root {
            --c-primary: #125E8A;
            --c-bg: #F3F3F3;
            --c-outline: #E2E8F0;
            --c-text: #1F2933;
            --c-muted: #6B7280;
            --c-surface: #E6F1F7;
            --r-card: 16px;
            --r-pill: 999px;
        }

        /* CSS filter: converts black SVG stroke → AppColors.balticBlue #125E8A */
        .icon-primary {
            filter: invert(27%) sepia(52%) saturate(701%) hue-rotate(172deg) brightness(90%) contrast(98%);
        }

        /* muted variant for chevrons → AppColors.mediumGrey #6B7280 */
        .icon-muted {
            filter: invert(46%) sepia(6%) saturate(531%) hue-rotate(176deg) brightness(93%) contrast(88%);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html,
        body {
            background: var(--c-bg);
        }

        body {
            color: var(--c-text);
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            padding-bottom: env(safe-area-inset-bottom, 0px);
        }

        /* ── APP BAR ── matches Flutter ShurpAppBar transparent + title */
        .app-bar {
            position: sticky;
            top: 0;
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 52px;
            /* AppSizes.appBar */
            background: var(--c-bg);
            border-bottom: 1px solid var(--c-outline);
            position: relative;
        }

        .app-bar-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--c-primary);
            letter-spacing: -0.3px;
        }

        /* ── PAGE WRAPPER — AppSpacing.lg = 16px sides ── */
        .page {
            max-width: 480px;
            margin: 0 auto;
            padding: 0 16px 48px;
        }

        /* ── SUBTITLE ── */
        .subtitle {
            text-align: center;
            font-size: 14px;
            color: var(--c-muted);
            padding: 14px 4px 20px;
            line-height: 1.55;
        }

        /* ── SECTION TITLE ── */
        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--c-text);
            letter-spacing: -0.3px;
            margin-bottom: 10px;
        }

        /* ── CARD GROUP — white rounded card, AppRadius ~16px ── */
        .card-group {
            background: white;
            border-radius: var(--r-card);
            overflow: hidden;
            margin-bottom: 28px;
            border: 1px solid var(--c-outline);
        }

        /* ── ROW ── */
        .help-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 16px;
            border-bottom: 1px solid var(--c-outline);
            cursor: pointer;
            text-decoration: none;
            color: var(--c-text);
            -webkit-tap-highlight-color: transparent;
            transition: background .1s;
        }

        .help-row:last-child {
            border-bottom: none;
        }

        .help-row:active {
            background: var(--c-surface);
        }

        .row-icon {
            flex-shrink: 0;
            width: 24px;
            height: 24px;
            /* AppSizes.icon */
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .row-icon img {
            width: 20px;
            height: 20px;
            display: block;
        }

        .row-label {
            flex: 1;
            font-size: 15px;
            font-weight: 500;
            color: var(--c-text);
        }

        .row-chevron {
            flex-shrink: 0;
            width: 16px;
            height: 16px;
            display: block;
        }

        /* ── LEGAL BLURB ── */
        .legal-blurb {
            font-size: 14px;
            line-height: 1.65;
            color: var(--c-text);
            text-align: justify;
            margin-bottom: 28px;
        }

        .legal-blurb a {
            color: var(--c-primary);
            font-weight: 600;
            text-decoration: none;
        }

        .legal-blurb a:hover {
            text-decoration: underline;
        }

        /* ── ASK SECTION ── */
        .ask-title {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: -0.3px;
            margin-bottom: 14px;
        }

        .form-textarea {
            width: 100%;
            min-height: 100px;
            padding: 14px 16px;
            background: white;
            border: 1.5px solid var(--c-outline);
            border-radius: var(--r-card);
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: var(--c-text);
            resize: none;
            outline: none;
            transition: border-color .15s;
            margin-bottom: 10px;
        }

        .form-textarea:focus {
            border-color: var(--c-primary);
        }

        .form-textarea::placeholder {
            color: var(--c-muted);
        }

        .form-input {
            width: 100%;
            padding: 14px 16px;
            background: white;
            border: 1.5px solid var(--c-outline);
            border-radius: var(--r-card);
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: var(--c-text);
            outline: none;
            transition: border-color .15s;
            margin-bottom: 6px;
        }

        .form-input:focus {
            border-color: var(--c-primary);
        }

        .form-input.error {
            border-color: #F4937C;
        }

        .form-input.error:focus {
            border-color: #F4937C;
        }

        .form-input::placeholder {
            color: var(--c-muted);
        }

        .form-helper {
            color: var(--c-muted);
            font-size: 12px;
            line-height: 1.4;
            margin: 0 4px 10px;
        }

        .form-helper.error {
            color: #F4937C;
            font-weight: 600;
        }

        .char-counter {
            color: var(--c-muted);
            font-size: 12px;
            margin: -6px 4px 10px;
            text-align: right;
        }

        .turnstile-container {
            height: 0;
            overflow: hidden;
        }

        .form-select-wrapper {
            position: relative;
            margin-bottom: 16px;
        }

        .form-select {
            width: 100%;
            padding: 14px 40px 14px 16px;
            background: white;
            border: 1.5px solid var(--c-outline);
            border-radius: var(--r-card);
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: var(--c-muted);
            outline: none;
            appearance: none;
            -webkit-appearance: none;
            cursor: pointer;
            transition: border-color .15s;
        }

        .form-select:focus {
            border-color: var(--c-primary);
        }

        .form-select.filled {
            color: var(--c-text);
        }

        .select-chevron-wrap {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            pointer-events: none;
            width: 16px;
            height: 16px;
        }

        /* ── SUBMIT BTN — matches ShurpButton primary ── */
        .submit-btn {
            display: block;
            width: 100%;
            padding: 16px;
            background: var(--c-primary);
            color: white;
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 16px;
            border: none;
            border-radius: var(--r-pill);
            cursor: pointer;
            transition: opacity .15s;
            margin-bottom: 32px;
            /* AppSizes.controlLg = 48px height */
            min-height: 48px;
        }

        .submit-btn:active {
            opacity: .82;
        }

        .submit-btn:disabled {
            cursor: wait;
            opacity: .65;
        }

        .success-banner {
            display: none;
            background: #E6F7EE;
            color: #1A7F4B;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 14px;
            font-weight: 600;
            text-align: center;
            margin-bottom: 16px;
        }

        .success-banner.error {
            background: #FDECEC;
            color: #A13434;
        }

        .mail-fallback {
            display: block;
            color: var(--c-primary);
            font-size: 14px;
            font-weight: 600;
            margin: -18px 0 30px;
            text-align: center;
            text-decoration: none;
        }

        /* ── MADE IN LATVIA ── */
        .mil-footer {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .mil-flag {
            display: flex;
            gap: 3px;
        }

        .mil-flag span {
            display: block;
            width: 9px;
            height: 28px;
            border-radius: 3px;
            background: #9E3039;
        }

        .mil-footer p {
            font-size: 13px;
            color: var(--c-muted);
        }

        /* ── CONTENT OVERLAYS — full-screen push ── */
        .overlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 100;
            background: var(--c-bg);
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        .overlay.open {
            display: block;
        }

        .overlay-bar {
            position: sticky;
            top: 0;
            z-index: 10;
            display: flex;
            align-items: center;
            gap: 12px;
            height: 52px;
            padding: 0 16px;
            background: var(--c-bg);
            border-bottom: 1px solid var(--c-outline);
        }

        .back-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 1.5px solid var(--c-outline);
            background: none;
            cursor: pointer;
            flex-shrink: 0;
            -webkit-tap-highlight-color: transparent;
            padding: 0;
        }

        .back-btn img {
            width: 20px;
            height: 20px;
            display: block;
        }

        .overlay-title {
            font-size: 17px;
            font-weight: 700;
            color: var(--c-text);
            letter-spacing: -0.2px;
        }

        .overlay-body {
            max-width: 480px;
            margin: 0 auto;
            padding: 20px 16px 48px;
        }

        /* overlay typography */
        .overlay-body h3 {
            font-size: 15px;
            font-weight: 700;
            color: var(--c-primary);
            margin: 20px 0 6px;
            padding-bottom: 6px;
            border-bottom: 1px solid var(--c-outline);
        }

        .overlay-body h3:first-child {
            margin-top: 0;
        }

        .overlay-body p {
            font-size: 14px;
            line-height: 1.65;
            color: rgba(31, 41, 51, .78);
            margin-bottom: 6px;
        }

        .overlay-body ul {
            padding-left: 18px;
            margin-bottom: 8px;
        }

        .overlay-body ul li {
            font-size: 14px;
            line-height: 1.65;
            color: rgba(31, 41, 51, .78);
            margin-bottom: 3px;
        }

        .overlay-body strong {
            color: var(--c-text);
            font-weight: 600;
        }

        .overlay-body .note {
            font-size: 12px;
            font-style: italic;
            color: var(--c-muted);
            margin-top: 14px;
            line-height: 1.5;
        }

        /* ── FAQ ACCORDION ── */
        .faq-item {
            border-bottom: 1px solid var(--c-outline);
        }

        .faq-item:last-child {
            border-bottom: none;
        }

        .faq-q {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 0;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            gap: 8px;
            -webkit-tap-highlight-color: transparent;
        }

        .faq-chevron {
            flex-shrink: 0;
            width: 18px;
            height: 18px;
            display: block;
            transition: transform .2s;
        }

        .faq-item.open .faq-chevron {
            transform: rotate(180deg);
            filter: invert(27%) sepia(52%) saturate(701%) hue-rotate(172deg) brightness(90%) contrast(98%);
        }

        .faq-a {
            display: none;
            font-size: 14px;
            line-height: 1.65;
            color: rgba(31, 41, 51, .78);
            padding-bottom: 14px;
        }

        .faq-a a {
            color: var(--c-primary);
            text-decoration: underline;
        }

        .faq-item.open .faq-a {
            display: block;
        }

        .lang-switch {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .08em;
        }

        .lang-switch .active {
            color: var(--c-primary);
        }

        .lang-switch .sep {
            color: var(--c-outline);
        }

        .lang-switch a {
            color: var(--c-muted);
            text-decoration: none;
            transition: color .15s;
        }

        .lang-switch a:hover {
            color: var(--c-primary);
        }
    </style>
</head>

<body>

    <!-- APP BAR -->
    <div class="app-bar">
        <span class="app-bar-title">Help</span>
        <div class="lang-switch">
            <span class="active">EN</span>
            <span class="sep">|</span>
            <a href="/lv/help">LV</a>
        </div>
    </div>

    <div class="page">

        <p class="subtitle">Having trouble with the app or something else? Find answers below or get in touch with us.
        </p>

        <!-- ══ USING THE APP ══ -->
        <p class="section-title">Using the app</p>
        <div class="card-group">

            <a class="help-row" onclick="openOverlay('how'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_star.svg" class="icon-primary" alt=""></span>
                <span class="row-label">How it works?</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('search'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_rides.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Searching rides</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('drive'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_drive.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Driving with Shurp</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('safety'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_verified.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Safety and trust</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

        </div>

        <!-- ══ FAQ ══ -->
        <p class="section-title">Frequently Asked Questions</p>
        <div class="card-group">

            <a class="help-row" onclick="openOverlay('faq-ver'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_verified.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Verification &amp; Safety</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('faq-priv'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_password.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Data privacy</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('faq-free'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_help.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Is Shurp free to use?</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('faq-profile'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_profile.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Car &amp; Profile management</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('faq-book'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_alert.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Booking &amp; Requests</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

            <a class="help-row" onclick="openOverlay('faq-rat'); return false;" href="#">
                <span class="row-icon"><img src="../assets/icons/icon_star.svg" class="icon-primary" alt=""></span>
                <span class="row-label">Ratings &amp; Community</span>
                <img src="../assets/icons/icon_right_chevron.svg" class="row-chevron icon-muted" alt="">
            </a>

        </div>

        <!-- ══ LEGAL ══ -->
        <p class="section-title">Legal</p>
        <p class="legal-blurb">Safety first. We use Didit ID verification to build a community you can trust. Your
            sensitive data is encrypted and never shared. Curious about the details? Read our <a
                href="privacy">Privacy</a> and <a href="terms">Terms &amp; Conditions.</a></p>

        <!-- ══ ASK A QUESTION ══ -->
        <p id="ask-section" class="ask-title">Ask a question or report a problem</p>

        <div class="success-banner" id="success-banner">✓ Sent! We'll get back to you shortly.</div>

        <input class="form-input" id="contact-email" type="email" inputmode="email" autocomplete="email" maxlength="50"
            placeholder="Email address (optional)" oninput="clearEmailError()">
        <p class="form-helper" id="email-helper"
            data-default="Add your email if you want us to reply, especially if you cannot log in yet.">Add your email
            if you want us to reply, especially if you cannot log in yet.</p>

        <textarea class="form-textarea" id="msg-text" maxlength="2000" placeholder="Your text here"
            oninput="updateCharCounter()"></textarea>
        <div class="char-counter" id="char-counter">0 / 2000</div>

        <div class="form-select-wrapper">
            <select class="form-select" id="msg-type" onchange="this.classList.add('filled')">
                <option value="" disabled selected>Choose type</option>
                <option value="Bug / App issue">Bug / App issue</option>
                <option value="Ride problem">Ride problem</option>
                <option value="Account & Profile">Account &amp; Profile</option>
                <option value="Safety concern">Safety concern</option>
                <option value="Payment / cost sharing">Payment / cost sharing</option>
                <option value="Other">Other</option>
            </select>
            <img src="../assets/icons/icon_left_chevron.svg" class="select-chevron-wrap icon-muted"
                style="transform:translateY(-50%) rotate(-90deg); position:absolute; right:14px; top:50%; pointer-events:none;"
                alt="">
        </div>

        <button class="submit-btn" id="submit-btn" onclick="submitForm(this)">Submit</button>
        <div id="turnstile-container" class="turnstile-container"></div>
        <a class="mail-fallback" href="#" onclick="openMailFallback(); return false;">Prefer email? Open mail app</a>

        <div class="mil-footer">
            <div class="mil-flag"><span></span><span></span></div>
            <p>Made in Latvia</p>
        </div>

    </div><!-- /page -->


    <!-- ══════════════════════════════════
         CONTENT OVERLAYS
    ══════════════════════════════════ -->

    <!-- HOW IT WORKS -->
    <div class="overlay" id="overlay-how">
        <div class="overlay-bar">
            <button class="back-btn" onclick="closeOverlay('how')">
                <img src="../assets/icons/icon_back.svg" class="icon-primary" alt="back">
            </button>
            <span class="overlay-title">How it works?</span>
