RewriteEngine On

# 1. Remove .html from the URL (Redirects privacy.html to /privacy)
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# 2. Serve the .html file internally (User sees /privacy, server reads privacy.html)
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^ %{REQUEST_URI}.html [NC,L]